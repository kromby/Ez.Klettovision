{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/assets/*.{js,css}",
      "headers": {
        "Cache-Control": "public, immutable, max-age=31536000"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.{css,js,png,svg,ico,json,woff2}"]
  },
  "globalHeaders": {
    "Cache-Control": "no-store"
  }
}
